# ============================================================
# AI Nexus — Environment Configuration Template
# Copy to .env and fill in your values before running.
# NEVER commit .env to version control.
# ============================================================

# --- Deployment Domains ---
API_DOMAIN=api.YOURDOMAIN.COM
DASHBOARD_DOMAIN=dash.YOURDOMAIN.COM
WEBUI_DOMAIN=YOURDOMAIN.COM
DASHBOARD_ORIGIN=https://dash.YOURDOMAIN.COM

# --- Installation Paths ---
AI_ROOT=/opt/ai
MODELS_ROOT=/opt/models
HUGGINGFACE_HOME=/opt/models/huggingface
LOG_DIR=/var/log/ai-nexus
AI_USER=ai

# --- Service Ports ---
GATEWAY_PORT=5050
VLLM_PORT=11434
PAYMENT_PORT=8003
DASHBOARD_PORT=8200
OPENWEBUI_PORT=3000
INVOKEAI_PORT=9090
ZEP_PORT=8010
GRAPHITI_PORT=8001
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
POSTGRES_PORT=5433
MCP_GATEWAY_PORT=8100

# --- vLLM Configuration ---
GPU_MEMORY_UTILIZATION=0.95
DEFAULT_MODE=extreme
VLLM_ATTENTION_BACKEND=TRITON_ATTN
# Context window per mode (tokens)
VLLM_MAX_LEN_EXTREME=49152
VLLM_MAX_LEN_CODE=65536
VLLM_MAX_LEN_FAST=98304
# Swap space (GiB of CPU RAM for KV cache spillover)
VLLM_SWAP_SPACE_EXTREME=14
VLLM_SWAP_SPACE_CODE=14
VLLM_SWAP_SPACE_FAST=8

# --- Database ---
KEYS_DB_PATH=/opt/ai/keys/keys.sqlite

# --- Gateway Upstreams ---
UPSTREAM_URL=http://127.0.0.1:11434
SD_URL=http://127.0.0.1:9090
ZEP_URL=http://localhost:8010
ZEP_API_KEY=your_zep_api_key_here

# --- Payment Processing (Stripe) ---
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key_here

# --- Payment Processing (Strike / Bitcoin Lightning) ---
STRIKE_API_KEY=your_strike_api_key_here
STRIKE_WEBHOOK_SECRET=your_strike_webhook_secret_here

# --- Email (SendGrid) ---
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
FROM_EMAIL=noreply@YOURDOMAIN.COM
FROM_NAME=AI Nexus

# --- Admin Authentication ---
# Comma-separated list of admin API keys for webhook management
ADMIN_API_KEYS=your_admin_key_1_here,your_admin_key_2_here

# --- Database Credentials ---
# Min 32 random characters — generate with: openssl rand -base64 32
NEO4J_PASSWORD=change_this_to_a_strong_random_password_min_32_chars
POSTGRES_PASSWORD=change_this_to_another_strong_random_password

# --- Knowledge Graph (Graphiti) ---
# Use local gateway or external OpenAI
OPENAI_BASE_URL=http://127.0.0.1:5050/v1
GATEWAY_API_KEY=pg_your_gateway_api_key_here

# --- Cloudflare (optional — for tunnel-based public access) ---
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# --- Feature Flags ---
ENABLE_PAYMENTS=true
ENABLE_SDXL=true
ENABLE_MCP=true
ENABLE_MEMORY=true
ENFORCE_EAGER=true
