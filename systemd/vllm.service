[Unit]
Description=vLLM Inference Server
After=network.target
Wants=network-online.target

[Service]
Type=simple
User=ai
Group=ai
WorkingDirectory=/opt/ai/vllm
Environment="HF_HOME=/opt/models/huggingface"
Environment="CUDA_VISIBLE_DEVICES=0"
Environment="VLLM_ATTENTION_BACKEND=FLASH_ATTN"

# Mistral-Small-3.2-24B (extreme mode) - general conversation & reasoning
ExecStart=/opt/ai/vllm/.venv/bin/vllm serve mistralai/Mistral-Small-3.2-24B-Instruct-2506 \
    --host 0.0.0.0 \
    --port 11434 \
    --gpu-memory-utilization 0.95 \
    --max-model-len 32768 \
    --dtype auto \
    --tokenizer_mode mistral \
    --config_format mistral \
    --load_format mistral \
    --enable-auto-tool-choice \
    --tool-call-parser mistral \
    --enable-chunked-prefill \
    --enable-prefix-caching \
    --served-model-name extreme

Restart=on-failure
RestartSec=10
StandardOutput=append:/opt/ai/vllm/logs/vllm.log
StandardError=append:/opt/ai/vllm/logs/vllm-error.log

[Install]
WantedBy=multi-user.target
