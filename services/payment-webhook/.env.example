# ========================================
# Payment Webhook Service Configuration
# ========================================
# Copy this file to .env and fill in your actual values
# Run: cp .env.example .env && chmod 600 .env

# ========================================
# Database
# ========================================
KEY_DB_PATH=/opt/ai/keys/keys.sqlite

# ========================================
# Server Configuration
# ========================================
HOST=0.0.0.0
PORT=8003
LOG_LEVEL=info
ENVIRONMENT=production  # development, staging, production

# ========================================
# Stripe Configuration
# ========================================
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx  # Get from https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx  # Get from webhook settings
STRIPE_API_VERSION=2023-10-16

# ========================================
# Strike Configuration
# ========================================
STRIKE_API_KEY=your_strike_api_key_here  # Get from https://dashboard.strike.me/
STRIKE_WEBHOOK_SECRET=your_strike_webhook_secret
STRIKE_API_BASE_URL=https://api.strike.me  # Production: https://api.strike.me

# ========================================
# BTCPay Server Configuration (Optional - Ultra Privacy Tier)
# ========================================
BTCPAY_ENABLED=false  # Set to 'true' to enable BTCPay integration
BTCPAY_ONION_URL=http://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.onion
BTCPAY_API_KEY=your_btcpay_api_key
BTCPAY_STORE_ID=your_store_id
BTCPAY_WEBHOOK_SECRET=your_btcpay_webhook_secret
BTCPAY_USE_POLLING=true  # Fallback to polling if webhooks don't work
BTCPAY_POLL_INTERVAL=15  # Seconds between polls

# ========================================
# Pricing Configuration
# ========================================
# Subscription Plans (monthly, all include 500k tokens)
PLAN_TRIAL_PRICE=5.00
PLAN_FAMILY_PRICE=18.00
PLAN_REGULAR_PRICE=25.00
PLAN_ULTRA_PRIVACY_PRICE=30.00
PLAN_BETA_PRICE=0.00

# Monthly token allowance for all plans
MONTHLY_TOKEN_ALLOWANCE=500000

# Token Packs (one-time purchases)
PACK_TRIAL_TOKENS=10000
PACK_TRIAL_PRICE=1.00

PACK_SMALL_TOKENS=100000
PACK_SMALL_PRICE=5.00

PACK_MEDIUM_TOKENS=500000
PACK_MEDIUM_PRICE=20.00

PACK_LARGE_TOKENS=1000000
PACK_LARGE_PRICE=35.00

# ========================================
# Email Configuration
# ========================================
EMAIL_PROVIDER=sendgrid  # Options: sendgrid, smtp, mailgun, postmark
EMAIL_FROM=noreply@playground.8ase0f0ps.com
EMAIL_FROM_NAME=Playground AI

# SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SMTP (if using SMTP provider)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_smtp_password
SMTP_TLS=true

# ========================================
# PGP Configuration (for Ultra Privacy tier)
# ========================================
GPG_HOME=/opt/ai/payment-webhook/.gnupg
GPG_KEY_BITS=4096
GPG_ENABLE_ENCRYPTION=true  # Set to false to disable PGP temporarily

# ========================================
# Website URLs
# ========================================
SIGNUP_WEBSITE_URL=https://playground.8ase0f0ps.com
API_DOCS_URL=https://api.playground.8ase0f0ps.com/docs
SUPPORT_EMAIL=support@playground.8ase0f0ps.com

# ========================================
# Security
# ========================================
# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://playground.8ase0f0ps.com,https://ai.playground.8ase0f0ps.com

# Admin API keys for protected endpoints (comma-separated)
# Generate secure keys with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Example: ADMIN_API_KEYS=key1_xxxxxxxxxx,key2_yyyyyyyyyy
ADMIN_API_KEYS=

# API rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60  # seconds

# ========================================
# Monitoring & Logging
# ========================================
ENABLE_STRUCTURED_LOGGING=true
SENTRY_DSN=  # Optional: Sentry error tracking
LOG_FILE_PATH=/opt/ai/payment-webhook/logs/webhook.log

# ========================================
# Development / Testing
# ========================================
DEBUG=false
TEST_MODE=false  # Use test payment providers
MOCK_EMAILS=false  # Don't send real emails in development
